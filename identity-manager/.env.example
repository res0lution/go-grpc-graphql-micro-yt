APP_ENV=development
LOG_LEVEL=info
APP_PORT=8088
GIN_MODE=debug
PORTAL_UI_HOST=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=identity_manager
DB_SSLMODE=disable

IDP_HOST=https://idp.example.com
IDP_CLIENT_ID=your-client-id
IDP_CLIENT_SECRET=your-client-secret
IDP_REDIRECT_URI=http://localhost:8088/v1/auth/callback
IDP_JWKS_URL=https://idp.example.com/oauth2/keys

CORE_BACKEND_URL=http://localhost:8080
CORE_INTERNAL_AUTH_TOKEN=replace-with-strong-shared-token

SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAMESITE=Lax
